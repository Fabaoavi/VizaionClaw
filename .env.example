# ─── Gravity Claw — Environment Variables ────────────────────────
# Copy this to .env and fill in your values.

# ── Required ──
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
OPENROUTER_API_KEY=your_openrouter_api_key
ALLOWED_USER_IDS=123456789  # Comma-separated Telegram user IDs

# ── LLM Settings ──
LLM_MODEL=llama-3.3-70b-versatile  # Any OpenRouter model ID
MAX_AGENT_ITERATIONS=10
THINKING_LEVEL=off  # off | low | medium | high

# ── Optional Provider Keys (adds failover + direct access) ──
# OPENAI_API_KEY=sk-...        # OpenAI direct (also enables Whisper + DALL-E)
# ANTHROPIC_API_KEY=sk-ant-... # Anthropic direct
GROQ_API_KEY=                   # Groq (fast inference)
# DEEPSEEK_API_KEY=            # DeepSeek direct
# GOOGLE_API_KEY=              # Google Gemini direct
# OLLAMA_URL=http://localhost:11434  # Local Ollama (auto-detected)

# ── Voice (Phase 4) ──
# ELEVENLABS_API_KEY=          # ElevenLabs TTS
# ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM  # Default: Rachel
